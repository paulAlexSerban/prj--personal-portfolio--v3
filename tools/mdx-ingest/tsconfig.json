{
    "compilerOptions": {
        "lib": ["ES2022"],
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": false,
        "types": ["node"],
        "outDir": "dist",
        "rootDir": "src",
        "composite": true,
        "declaration": true
    },
    "include": ["src/**/*.ts", "src/**/*.js"],
    "exclude": ["node_modules"],
    "references": [{ "path": "../../shared/taskManager" }],
    "extends": "../../tsconfig.base.json"
}
