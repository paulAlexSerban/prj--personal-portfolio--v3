---
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CoreSkills from '../components/CoreSkills.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import FeaturedBlog from '../components/FeaturedBlog.astro';
import HeroSplit from '../components/HeroSplit.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { closeConnection, openDb } from '../lib/db.ts';
import { getExperienceTimeline } from '../lib/queries/experience.ts';
import { getFeaturedPost, getRecentPosts } from '../lib/queries/posts.ts';
import { buildProjectTagsMap, getFeaturedPreview } from '../lib/queries/projects.ts';
import { getProfile } from '../lib/queries/profile.ts';
import { getSkillsGrouped } from '../lib/queries/skills.ts';
import { assetUrl, externalLinkAttrs, siteUrls } from '../lib/urls.ts';

const db = openDb();
const profile = getProfile(db);
const experience = getExperienceTimeline(db);
const skillGroups = getSkillsGrouped(db);
const featured = getFeaturedPreview(db, 3);
const featuredTags = buildProjectTagsMap(db, featured);
const featuredPost = getFeaturedPost(db);
const recentPosts = getRecentPosts(db, 3);
closeConnection(db);

const name = profile?.name ?? 'Paul Serban';
const description = profile?.headline ?? 'Portfolio of Paul Serban.';
---

<BaseLayout title={`${name} | Portfolio`} description={description} ogImage={profile?.photo_url ?? assetUrl('portrait.svg')}>
    <HeroSplit profile={profile} />

    <ExperienceTimeline items={experience} />

    {
        skillGroups.length > 0 && (
            <section class="mb-12">
                <p class="kicker text-sm">Toolkit</p>
                <h2 class="m-0 font-display text-4xl font-bold">What I bring to the stack</h2>
                <p class="deck mt-2 mb-6 max-w-prose">Not a keyword wall — the tools I reach for and the value each one delivers.</p>
                <CoreSkills groups={skillGroups} />
                <div class="rule-thin mt-8" />
            </section>
        )
    }

    {
        featured.length > 0 && (
            <section class="mb-12">
                <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
                    <div>
                        <p class="kicker text-sm">Selected work</p>
                        <h2 class="m-0 font-display text-4xl font-bold">Case studies</h2>
                    </div>
                    <a class="stamp stamp-ghost px-4 py-1.5 text-sm" href={siteUrls.portfolio}>View all &rarr;</a>
                </div>
                <ul class="m-0 grid list-none grid-cols-[repeat(auto-fill,minmax(18rem,1fr))] gap-8 p-0">
                    {featured.map((project) => (
                        <li>
                            <CaseStudyCard project={project} tags={featuredTags.get(project.slug) ?? []} featured />
                        </li>
                    ))}
                </ul>
                <div class="rule-thin mt-10" />
            </section>
        )
    }

    {featuredPost && <FeaturedBlog post={featuredPost} />}

    {
        recentPosts.length > 1 && (
            <section class="mb-12">
                <p class="kicker text-sm">More reading</p>
                <h2 class="m-0 mb-5 font-display text-3xl font-bold">Recent posts</h2>
                <ul class="m-0 grid list-none gap-0 p-0">
                    {recentPosts.slice(featuredPost ? 1 : 0).map((post) => (
                        <li class="border-b border-rule py-3 last:border-b-0">
                            <a
                                href={siteUrls.blogPost(post.slug)}
                                class="text-ink no-underline hover:underline"
                                {...externalLinkAttrs(siteUrls.blogPost(post.slug))}
                            >
                                <span class="kicker text-[11px]">{post.date}</span>
                                <span class="ml-3 font-display font-bold">{post.title}</span>
                            </a>
                        </li>
                    ))}
                </ul>
            </section>
        )
    }
</BaseLayout>
