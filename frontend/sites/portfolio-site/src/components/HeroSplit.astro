---
import type { ProfileRow } from '@prj--personal-portfolio--v3/shared--db-schema';
import { externalLinkAttrs, siteUrls } from '../lib/urls.ts';

interface Props {
    profile: ProfileRow | undefined;
}

const { profile } = Astro.props;
const name = profile?.name ?? 'Paul Serban';
const headline = profile?.headline ?? 'I architect systems that ship.';
---

<section class="mb-12">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
            <p class="kicker mb-2 text-sm">{name}</p>
            <h2 class="m-0 font-display text-[clamp(2.25rem,6vw,3.75rem)] font-bold leading-[1.05]">
                {headline}
            </h2>
            {profile?.bio && (
                <p class="deck mt-4 max-w-prose text-[1.05rem] line-clamp-3">{profile.bio}</p>
            )}
            <div class="mt-6 flex flex-wrap gap-3">
                <a class="stamp px-5 py-2 text-sm" href={siteUrls.portfolio}>View work &rarr;</a>
                <a class="stamp stamp-ghost px-5 py-2 text-sm" href={siteUrls.blog} {...externalLinkAttrs(siteUrls.blog)}>
                    Read blog &rarr;
                </a>
            </div>
            {
                (profile?.github_url || profile?.linkedin_url) && (
                    <div class="mt-5 flex flex-wrap gap-4 text-[11px] smallcaps">
                        {profile?.github_url && (
                            <a class="text-ink underline-offset-2 hover:underline" href={profile.github_url} rel="noopener noreferrer" target="_blank">GitHub</a>
                        )}
                        {profile?.linkedin_url && (
                            <a class="text-ink underline-offset-2 hover:underline" href={profile.linkedin_url} rel="noopener noreferrer" target="_blank">LinkedIn</a>
                        )}
                    </div>
                )
            }
        </div>
        <div class="flex flex-col items-center gap-4">
            <figure class="m-0 w-full max-w-md border border-ink bg-aged p-4">
                <svg viewBox="0 0 400 280" width="100%" height="auto" role="img" aria-label="Architecture: an event-driven control plane orchestrating parallel LLM agents, observed end to end" class="font-mono text-ink">
                    <title>Agentic AI control plane</title>
                    <defs>
                        <marker id="hero-arrow" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto">
                            <path d="M0 0 L6 3 L0 6 Z" fill="currentColor"></path>
                        </marker>
                    </defs>

                    <!-- Events (input) -->
                    <rect x="12" y="110" width="92" height="58" fill="none" stroke="currentColor" stroke-width="1.5"></rect>
                    <text x="58" y="135" text-anchor="middle" font-size="11" fill="currentColor">Events</text>
                    <text x="58" y="151" text-anchor="middle" font-size="8" fill="currentColor" fill-opacity="0.65">PR · launch · cron</text>

                    <!-- Control plane (emphasis) -->
                    <rect x="148" y="96" width="104" height="86" fill="var(--highlight)" stroke="currentColor" stroke-width="2"></rect>
                    <text x="200" y="130" text-anchor="middle" font-size="11" fill="currentColor">Control</text>
                    <text x="200" y="146" text-anchor="middle" font-size="11" fill="currentColor">Plane</text>
                    <text x="200" y="164" text-anchor="middle" font-size="8" fill="currentColor" fill-opacity="0.65">orchestrate · cache</text>

                    <!-- Parallel agents (fan-out) -->
                    <rect x="300" y="22" width="88" height="46" fill="none" stroke="currentColor" stroke-width="1.5"></rect>
                    <text x="344" y="42" text-anchor="middle" font-size="10" fill="currentColor">Agent</text>
                    <text x="344" y="55" text-anchor="middle" font-size="7" fill="currentColor" fill-opacity="0.65">Bedrock</text>
                    <rect x="300" y="110" width="88" height="46" fill="none" stroke="currentColor" stroke-width="1.5"></rect>
                    <text x="344" y="130" text-anchor="middle" font-size="10" fill="currentColor">Agent</text>
                    <text x="344" y="143" text-anchor="middle" font-size="7" fill="currentColor" fill-opacity="0.65">AgentCore</text>
                    <rect x="300" y="198" width="88" height="46" fill="none" stroke="currentColor" stroke-width="1.5"></rect>
                    <text x="344" y="218" text-anchor="middle" font-size="10" fill="currentColor">Agent</text>
                    <text x="344" y="231" text-anchor="middle" font-size="7" fill="currentColor" fill-opacity="0.65">…×N</text>

                    <!-- Flow -->
                    <line x1="104" y1="139" x2="142" y2="139" stroke="currentColor" stroke-width="1.5" marker-end="url(#hero-arrow)"></line>
                    <line x1="252" y1="122" x2="294" y2="48" stroke="currentColor" stroke-width="1.5" marker-end="url(#hero-arrow)"></line>
                    <line x1="252" y1="139" x2="294" y2="133" stroke="currentColor" stroke-width="1.5" marker-end="url(#hero-arrow)"></line>
                    <line x1="252" y1="156" x2="294" y2="219" stroke="currentColor" stroke-width="1.5" marker-end="url(#hero-arrow)"></line>

                    <!-- Observability rail -->
                    <line x1="12" y1="262" x2="388" y2="262" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3"></line>
                    <text x="200" y="276" text-anchor="middle" font-size="8" fill="currentColor" fill-opacity="0.65" letter-spacing="0.08em">OBSERVABILITY · DATADOG · GRAFANA</text>
                </svg>
                <figcaption class="kicker mt-2 text-center text-[10px]">Event-driven control plane, parallel LLM agents</figcaption>
            </figure>
        </div>
    </div>
    <div class="rule mt-10"></div>
</section>
