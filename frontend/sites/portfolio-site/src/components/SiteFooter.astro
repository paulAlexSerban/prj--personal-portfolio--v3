---
import { FooterSiteLinks, buildSiteTabs } from '@prj--personal-portfolio--v3/shared--navigation';
import { externalLinkAttrs, siteUrls } from '../lib/urls.ts';

const footerLinks = [
    { label: 'Home', href: siteUrls.home },
    { label: 'Experience', href: siteUrls.experience },
    { label: 'Portfolio', href: siteUrls.portfolio },
];

const siteTabs = buildSiteTabs({
    portfolio: siteUrls.home,
    blog: siteUrls.blog,
    quiz: siteUrls.quiz,
});

const year = new Date().getFullYear();
---

<footer class="mt-8 border-t-2 border-ink">
    <div class="root-box text-center">
        <nav aria-label="Footer" class="mb-3">
            <ul class="m-0 flex list-none flex-wrap justify-center gap-x-6 gap-y-3 p-0 text-[11px] smallcaps">
                {
                    footerLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="text-ink no-underline hover:underline"
                                {...externalLinkAttrs(link.href)}
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
        <div class="mb-3">
            <FooterSiteLinks activeSite="portfolio" tabs={siteTabs} />
        </div>
        <p class="kicker text-sm">Paul Serban · Printed in your browser · {year}</p>
    </div>
</footer>
