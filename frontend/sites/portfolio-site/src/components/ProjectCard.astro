---
import type { ProjectRow, TagRow } from '@prj--personal-portfolio--v3/shared--db-schema';

import TagList from './TagList.astro';

interface Props {
    project: ProjectRow;
    tags: TagRow[];
}

const { project, tags } = Astro.props;

const href = `/portfolio/${project.slug}/`;
---

<article class="card-ruled border-b border-rule pb-4">
    {project.pinned && <p class="kicker mb-1 text-[10px]">Featured</p>}
    <h2 class="font-display text-2xl font-bold leading-tight">
        <a href={href} class="text-ink no-underline hover:underline">{project.title}</a>
    </h2>
    {project.subheading && <p class="deck mt-1 text-sm">{project.subheading}</p>}
    {project.excerpt && <p class="mt-2 text-base text-charcoal line-clamp-3">{project.excerpt}</p>}
    <div class="rule-thin my-4"></div>
    <TagList tags={tags} />
    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-[10px] smallcaps">
        <a href={href} class="kicker hover:underline">Case study &rarr;</a>
        {
            project.repo_url && (
                <a
                    href={project.repo_url}
                    class="kicker hover:underline"
                    rel="noopener noreferrer"
                    target="_blank"
                >
                    Code
                </a>
            )
        }
        {
            project.demo_url && (
                <a
                    href={project.demo_url}
                    class="kicker hover:underline"
                    rel="noopener noreferrer"
                    target="_blank"
                >
                    Live
                </a>
            )
        }
    </div>
</article>
