---
import type { SkillRow } from '@prj--personal-portfolio--v3/shared--db-schema';
import SkillIcon from './SkillIcon.astro';

interface SkillGroup {
    category: string;
    skills: SkillRow[];
}

interface Props {
    groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<div class="grid gap-x-10 gap-y-8 md:grid-cols-2">
    {
        groups.map((group) => (
            <section>
                <p class="kicker text-[11px]">{group.category}</p>
                <div class="rule-thin mt-1 mb-2" />
                <ul class="m-0 list-none p-0">
                    {group.skills.map((skill) => (
                        <li class="flex items-start gap-3 border-b border-rule py-3 last:border-b-0">
                            <span class="grid h-10 w-10 shrink-0 place-items-center border border-ink bg-aged p-2 text-ink">
                                <SkillIcon name={skill.name} class="h-full w-full" />
                            </span>
                            <div class="min-w-0">
                                <p class="m-0 font-display text-base font-bold leading-tight">{skill.name}</p>
                                {skill.depth_note && (
                                    <p class="mt-0.5 text-sm leading-snug text-charcoal">{skill.depth_note}</p>
                                )}
                            </div>
                        </li>
                    ))}
                </ul>
            </section>
        ))
    }
</div>
