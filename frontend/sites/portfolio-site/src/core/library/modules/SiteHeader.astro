---
import { MobileNav, SiteSwitcher, buildSiteTabs } from '@prj--personal-portfolio--v3/shared--navigation';
import { externalLinkAttrs, isNavLinkActive, siteUrls } from '@/lib/urls.ts';

const navLinks = [
    { label: 'Home', href: siteUrls.home },
    { label: 'Experience', href: siteUrls.experience },
    { label: 'Portfolio', href: siteUrls.portfolio },
];

const siteTabs = buildSiteTabs({
    portfolio: siteUrls.home,
    blog: siteUrls.blog,
    quiz: siteUrls.quiz,
});

const pathname = Astro.url.pathname;

const mobileNavLinks = navLinks.map((link) => ({ ...link, active: isNavLinkActive(pathname, link.href) }));

const year = new Date().getFullYear();
---

<header class="grain border-b-[3px] border-ink bg-aged">
    <div class="root-box">
        <div class="flex items-center justify-between gap-4">
            <p class="kicker font-mono text-[10px] md:text-sm">paulserban.eu</p>
            <div class="flex flex-col items-end gap-1">
                <p class="kicker font-mono text-[10px] md:text-sm">Portfolio Edition</p>
                <SiteSwitcher activeSite="portfolio" tabs={siteTabs} />
            </div>
        </div>
        <a href={siteUrls.home} class="mt-2 block text-center text-ink no-underline">
            <h1 class="font-display font-black leading-none tracking-tight text-[clamp(2.5rem,8vw,5rem)]">
                Paul Serban
            </h1>
        </a>
        <p class="deck mt-2 text-center text-sm">AI &amp; full-stack engineer &middot; agentic platforms &middot; distributed systems</p>
        <div class="rule-double mt-3"></div>
        <div class="mt-2 flex flex-wrap items-center justify-between gap-2">
            <p class="kicker text-[11px]">Vol. {year}</p>
            <div class="flex items-center gap-3 md:gap-5">
                <nav class="hidden md:flex flex-wrap items-center gap-5 text-[11px] smallcaps" aria-label="Primary">
                    {
                        navLinks.map((link) => (
                            <a
                                href={link.href}
                                aria-current={isNavLinkActive(pathname, link.href) ? 'page' : undefined}
                                class="text-ink no-underline hover:underline aria-[current=page]:font-bold aria-[current=page]:underline"
                                {...externalLinkAttrs(link.href)}
                            >
                                {link.label}
                            </a>
                        ))
                    }
                </nav>
                <button
                    id="theme-toggle"
                    type="button"
                    aria-label="Toggle dark mode"
                    title="Toggle dark mode"
                    class="kicker inline-flex items-center gap-1.5 border border-ink px-2 py-1 text-[11px] leading-none transition-colors hover:bg-ink hover:text-aged"
                >
                    <span id="theme-toggle-icon" aria-hidden="true">☾</span>
                    <span id="theme-toggle-label">Dark</span>
                </button>
                <MobileNav client:load links={mobileNavLinks} />
            </div>
        </div>
    </div>
</header>

<script is:inline>
    (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) {return};
        const icon = document.getElementById('theme-toggle-icon');
        const label = document.getElementById('theme-toggle-label');
        const sync = () => {
            const dark = document.documentElement.classList.contains('dark');
            if (icon) icon.textContent = dark ? '☀' : '☾';
            if (label) label.textContent = dark ? 'Light' : 'Dark';
            btn.setAttribute('aria-pressed', String(dark));
        }
        sync();
        btn.addEventListener('click', () => {
            const dark = document.documentElement.classList.toggle('dark');
            try { 
                localStorage.setItem('theme', dark ? 'dark' : 'light'); 
            } catch (e) {
                console.error(e);
            }
            sync();
        });
    })();
</script>
