---
import type { TagRow } from '@prj--personal-portfolio--v3/shared--db-schema';

import TagList from './TagList.astro';

interface Props {
    title: string;
    subheading?: string;
    tags?: TagRow[];
}

const { title, subheading, tags = [] } = Astro.props;
---

<section class="mb-8 border-b border-dashed border-rule pb-6">
    <h1 class="m-0 mb-2 font-display text-[clamp(2rem,5vw,3rem)] leading-[1.1]">{title}</h1>
    {subheading && <p class="mt-0 mb-4 text-[1.1rem] text-slate-ink">{subheading}</p>}
    {tags.length > 0 && <TagList tags={tags} />}
</section>
