---
const navLinks = [
    { label: 'Blog', href: '/' },
    { label: 'Posts', href: '/post/' },
    { label: 'Snippets', href: '/snippet/' },
    { label: 'Book Notes', href: '/booknote/' },
];

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
    if (href === '/') {
        return pathname === '/' || pathname === '';
    }
    return pathname.startsWith(href);
}
---

<header class="border-b-2 border-ink bg-aged px-6 py-4">
    <div class="mx-auto flex max-w-[72rem] flex-wrap items-center justify-between gap-4">
        <a
            class="font-display text-2xl font-black tracking-[-0.02em] text-ink no-underline"
            href="/">Paul Serban</a
        >
        <nav aria-label="Primary">
            <ul class="m-0 flex list-none flex-wrap gap-x-5 gap-y-2 p-0">
                {
                    navLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                aria-current={isActive(link.href) ? 'page' : undefined}
                                class="text-[0.95rem] capitalize text-slate-ink no-underline hover:font-bold hover:text-ink aria-[current=page]:font-bold aria-[current=page]:text-ink"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>
