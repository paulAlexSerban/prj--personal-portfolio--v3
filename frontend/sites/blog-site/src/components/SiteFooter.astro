---
const footerLinks = [
    { label: 'Blog', href: '/' },
    { label: 'Posts', href: '/post/' },
    { label: 'Snippets', href: '/snippet/' },
    { label: 'Book Notes', href: '/booknote/' },
];
---

<footer class="border-t-2 border-ink bg-aged px-6 py-8">
    <div class="mx-auto max-w-[72rem]">
        <nav aria-label="Footer">
            <ul class="m-0 flex list-none flex-wrap gap-x-6 gap-y-3 p-0">
                {
                    footerLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="text-slate-ink no-underline hover:text-ink"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</footer>
