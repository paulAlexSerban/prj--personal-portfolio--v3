---
import { FooterSiteLinks, buildSiteTabs } from '@prj--personal-portfolio--v3/shared--navigation';
import { externalLinkAttrs, siteUrls } from '../lib/urls.ts';

const footerLinks = [
    { label: 'Posts', href: siteUrls.post },
    { label: 'Snippets', href: siteUrls.snippet },
    { label: 'Book Notes', href: siteUrls.booknote },
];

const siteTabs = buildSiteTabs({
    portfolio: siteUrls.portfolio,
    blog: siteUrls.home,
    quiz: siteUrls.quiz,
});

const year = new Date().getFullYear();
---

<footer class="mt-8 border-t-2 border-ink px-6 py-10">
    <div class="mx-auto max-w-[72rem] text-center">
        <nav aria-label="Footer" class="mb-3">
            <ul class="m-0 flex list-none flex-wrap justify-center gap-x-6 gap-y-3 p-0 text-[11px] smallcaps">
                {
                    footerLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="text-ink no-underline hover:underline"
                                {...externalLinkAttrs(link.href)}
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
        <div class="mb-3">
            <FooterSiteLinks activeSite="blog" tabs={siteTabs} />
        </div>
        <p class="kicker text-sm">Paul Serban · Printed in your browser · {year}</p>
    </div>
</footer>
