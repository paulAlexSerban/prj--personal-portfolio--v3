---
import type { PostRow, TagRow } from '@prj--personal-portfolio--v3/shared--db-schema';

import TagList from './TagList.astro';

import type { BlogContentType } from '../lib/queries/posts.ts';

interface Props {
    post: PostRow;
    tags: TagRow[];
    type: BlogContentType;
}

const { post, tags, type } = Astro.props;

function detailHref(contentType: BlogContentType, slug: string): string {
    if (contentType === 'book-note') {
        return `/booknote/${slug}/`;
    }
    return `/${contentType}/${slug}/`;
}

const href = detailHref(type, post.slug);
---

<article class="flex flex-col gap-3 border-2 border-ink bg-aged p-4">
    <h2 class="m-0 font-display text-[1.15rem] leading-[1.25]">
        <a href={href} class="text-inherit no-underline hover:underline">{post.title}</a>
    </h2>
    {post.date && <p class="m-0 text-[0.85rem] text-slate-ink">{post.date}</p>}
    {post.excerpt && <p class="m-0 text-[0.95rem] leading-[1.5] text-charcoal">{post.excerpt}</p>}
    <TagList tags={tags} />
</article>
