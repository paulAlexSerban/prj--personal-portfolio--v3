---
import HeroBanner from '../../components/HeroBanner.astro';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { closeConnection, openDb } from '../../lib/db.ts';
import { buildTagsMap, getPublishedByType } from '../../lib/queries/posts.ts';

const db = openDb();
const items = getPublishedByType(db, 'book-note');
const tagsMap = buildTagsMap(db, items);
closeConnection(db);
---

<BaseLayout title="Book Notes | Paul Serban" description="Book notes and reading summaries by Paul Serban.">
    <HeroBanner title="Book Notes" subheading="Notes and takeaways from books I read." />
    {
        items.length > 0 ? (
            <ul class="m-0 grid list-none grid-cols-[repeat(auto-fill,minmax(18rem,1fr))] gap-5 p-0">
                {items.map((item) => (
                    <li>
                        <PostCard post={item} tags={tagsMap.get(item.slug) ?? []} type="book-note" />
                    </li>
                ))}
            </ul>
        ) : (
            <p>No published book notes yet.</p>
        )
    }
</BaseLayout>
