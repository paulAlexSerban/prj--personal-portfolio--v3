---
import type { BlogPostFilterItem } from '@prj--personal-portfolio--v3/shared--ui/post-filters';

import HeroBanner from '../../components/HeroBanner.astro';
import { PostListIsland } from '../../components/PostListIsland.tsx';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { closeConnection, openDb } from '../../lib/db.ts';
import { buildTagsMap, getPublishedByType } from '../../lib/queries/posts.ts';

const db = openDb();
const items = getPublishedByType(db, 'book-note');
const tagsMap = buildTagsMap(db, items);
closeConnection(db);

const posts: BlogPostFilterItem[] = items.map((item) => ({
    title: item.title,
    slug: item.slug,
    excerpt: item.excerpt ?? null,
    date: item.date ?? null,
    type: 'book-note',
    tags: (tagsMap.get(item.slug) ?? []).map((t) => ({ name: t.name, slug: t.slug })),
}));
---

<BaseLayout title="Book Notes | Paul Serban" description="Book notes and reading summaries by Paul Serban.">
    <HeroBanner
        title="Book Notes"
        subheading="Notes and takeaways from books I read."
        kicker="The Catalogue"
    />
    {
        posts.length > 0 ? (
            <PostListIsland posts={posts} client:load />
        ) : (
            <p>No published book notes yet.</p>
        )
    }
</BaseLayout>
