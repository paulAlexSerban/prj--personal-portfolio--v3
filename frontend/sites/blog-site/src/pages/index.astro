---
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { closeConnection, openDb } from '../lib/db.ts';
import { buildTagsMap, getPinnedByType } from '../lib/queries/posts.ts';

const db = openDb();
const posts = getPinnedByType(db, 'post');
const snippets = getPinnedByType(db, 'snippet');
const booknotes = getPinnedByType(db, 'book-note');
const tagsMap = buildTagsMap(db, [...posts, ...snippets, ...booknotes]);
closeConnection(db);

const sections = [
    {
        title: 'Posts',
        viewAllHref: '/post/',
        viewAllLabel: 'View all Posts',
        items: posts,
        type: 'post' as const,
    },
    {
        title: 'Snippets',
        viewAllHref: '/snippet/',
        viewAllLabel: 'View all Snippets',
        items: snippets,
        type: 'snippet' as const,
    },
    {
        title: 'Book Notes',
        viewAllHref: '/booknote/',
        viewAllLabel: 'View all Book Notes',
        items: booknotes,
        type: 'book-note' as const,
    },
];
---

<BaseLayout title="Blog | Paul Serban" description="Posts, snippets, and book notes by Paul Serban.">
    {
        sections.map((section) => (
            <section class="mb-12">
                <div class="mb-5 flex flex-wrap items-baseline justify-between gap-3 border-b-2 border-ink pb-2">
                    <h2 class="m-0 font-display text-[1.75rem]">{section.title}</h2>
                    <a
                        class="font-bold text-ink no-underline hover:underline"
                        href={section.viewAllHref}
                    >
                        {section.viewAllLabel}
                    </a>
                </div>
                {section.items.length > 0 ? (
                    <ul class="m-0 grid list-none grid-cols-[repeat(auto-fill,minmax(18rem,1fr))] gap-5 p-0">
                        {section.items.map((item) => (
                            <li>
                                <PostCard
                                    post={item}
                                    tags={tagsMap.get(item.slug) ?? []}
                                    type={section.type}
                                />
                            </li>
                        ))}
                    </ul>
                ) : (
                    <p>No pinned {section.title.toLowerCase()} yet.</p>
                )}
            </section>
        ))
    }
</BaseLayout>
