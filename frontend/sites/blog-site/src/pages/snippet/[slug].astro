---
import PostTemplate from '@/system/templates/PostTemplate.astro';

import { closeConnection, openDb } from '@/lib/db.ts';
import { getPostStaticPaths } from '@/lib/queries/posts.ts';

export function getStaticPaths() {
    const db = openDb();
    const paths = getPostStaticPaths(db, 'snippet');
    closeConnection(db);
    return paths;
}

const slug = Astro.params.slug!;
---

<PostTemplate slug={slug} contentType="snippet" />
