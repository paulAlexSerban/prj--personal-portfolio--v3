---
import { evaluate } from '@mdx-js/mdx';
import { rehypePlugins, remarkPlugins } from '@prj--personal-portfolio--v3/shared--markdown';
import * as runtime from 'react/jsx-runtime';

import HeroBanner from '../../components/HeroBanner.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { closeConnection, openDb } from '../../lib/db.ts';
import { mdxComponents } from '../../lib/mdx-components.ts';
import {
    getAllSlugs,
    getPostBySlug,
    getQuestionCountForPost,
    getTagsForPost,
} from '../../lib/queries/posts.ts';

export function getStaticPaths() {
    const db = openDb();
    const slugs = getAllSlugs(db, 'snippet');
    closeConnection(db);
    return slugs.map(({ slug }) => ({ params: { slug } }));
}

const slug = Astro.params.slug!;
const db = openDb();
const post = getPostBySlug(db, slug);
const tags = getTagsForPost(db, slug);
const questionCount = getQuestionCountForPost(db, slug);
closeConnection(db);

if (!post) {
    throw new Error(`Snippet not found: ${slug}`);
}

const { default: Content } = await evaluate(post.body, {
    ...runtime,
    remarkPlugins: [...remarkPlugins],
    rehypePlugins: [...rehypePlugins],
});

const description = post.excerpt ?? post.subheading ?? undefined;
const canonicalUrl = new URL(`/snippet/${slug}/`, Astro.site).href;
---

<BaseLayout
    title={`${post.title} | Paul Serban`}
    description={description}
    ogTitle={post.title}
    ogDescription={description}
    canonicalUrl={canonicalUrl}
>
    <HeroBanner
        title={post.title}
        subheading={post.subheading ?? undefined}
        tags={tags}
        cover={post.cover_image ?? '/placeholder-cover.png'}
    />
    <article class="md-content mt-4">
        <Content components={mdxComponents} />
    </article>
    {
        questionCount > 0 && (
            <div
                id="quiz-widget-mount"
                class="quiz-widget-slot mt-12 min-h-16 border-2 border-dashed border-rule bg-highlight p-6"
                data-quiz-widget
                data-post-slug={post.slug}
            />
        )
    }
</BaseLayout>
