---
import type { BlogPostFilterItem } from '@prj--personal-portfolio--v3/shared--ui/post-filters';

import HeroBanner from '../../components/HeroBanner.astro';
import { PostListIsland } from '../../components/PostListIsland';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { closeConnection, openDb } from '../../lib/db.ts';
import { buildTagsMap, getPublishedByType } from '../../lib/queries/posts.ts';

const db = openDb();
const items = getPublishedByType(db, 'snippet');
const tagsMap = buildTagsMap(db, items);
closeConnection(db);

const posts: BlogPostFilterItem[] = items.map((item) => ({
    title: item.title,
    slug: item.slug,
    excerpt: item.excerpt ?? null,
    date: item.date ?? null,
    cover: item.cover_image ?? null,
    type: 'snippet',
    tags: (tagsMap.get(item.slug) ?? []).map((t) => ({ name: t.name, slug: t.slug })),
}));
---

<BaseLayout title="Snippets | Paul Serban" description="Code snippets and quick notes by Paul Serban.">
    <HeroBanner
        title="Snippets"
        subheading="Short code notes and quick references."
        kicker="The Catalogue"
    />
    {
        posts.length > 0 ? (
            <PostListIsland posts={posts} client:load />
        ) : (
            <p>No published snippets yet.</p>
        )
    }
</BaseLayout>
