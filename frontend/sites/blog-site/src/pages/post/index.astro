---
import type { BlogPostFilterItem } from '@prj--personal-portfolio--v3/shared--ui/post-filters';

import HeroBanner from '@/library/modules/HeroBanner.astro';
import { PostListIsland } from '@/library/widgets/PostListIsland.tsx';
import BaseLayout from '@/system/templates/BaseTemplate.astro';

import { closeConnection, openDb } from '@/lib/db.ts';
import { buildTagsMap, getPublishedByType } from '@/lib/queries/posts.ts';

const db = openDb();
const items = getPublishedByType(db, 'post');
const tagsMap = buildTagsMap(db, items);
closeConnection(db);

const posts: BlogPostFilterItem[] = items.map((item) => ({
    title: item.title,
    slug: item.slug,
    excerpt: item.excerpt ?? null,
    date: item.date ?? null,
    cover: item.cover_image ?? null,
    type: 'post',
    tags: (tagsMap.get(item.slug) ?? []).map((t) => ({ name: t.name, slug: t.slug })),
}));
---

<BaseLayout title="Posts | Paul Serban" description="All published posts by Paul Serban.">
    <HeroBanner title="Posts" subheading="Articles and long-form writing." kicker="The Catalogue" />
    {
        posts.length > 0 ? (
            <PostListIsland posts={posts} client:load />
        ) : (
            <p>No published posts yet.</p>
        )
    }
</BaseLayout>
