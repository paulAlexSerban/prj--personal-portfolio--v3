---
import type { TagRow } from '@prj--personal-portfolio--v3/shared--db-schema';
import { coverImageUrl } from '@prj--personal-portfolio--v3/shared--ui/cover-image';

import TagList from '@/library/components/TagList.astro';

interface Props {
    title: string;
    subheading?: string;
    tags?: TagRow[];
    kicker?: string;
    cover?: string;
}

const PLACEHOLDER_COVER = '/placeholder-cover.png';

const { title, subheading, tags = [], kicker, cover } = Astro.props;
---

<section class="mb-8 border-b-[3px] border-ink pb-6">
    {
        cover && (
            <img
                src={coverImageUrl(cover, PLACEHOLDER_COVER)}
                alt=""
                loading="eager"
                class="mb-6 aspect-video w-full border border-rule object-cover"
            />
        )
    }
    {kicker && <p class="kicker mb-2 text-sm">{kicker}</p>}
    <h1 class="m-0 font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-[1.1]">{title}</h1>
    {subheading && <p class="deck mt-2 mb-4 text-[1.1rem]">{subheading}</p>}
    {tags.length > 0 && <TagList tags={tags} />}
</section>
