---
import type { PostRow, TagRow } from '@prj--personal-portfolio--v3/shared--db-schema';
import { CoverImage } from '@prj--personal-portfolio--v3/shared--ui/cover-image-ui';

import TagList from '@/library/components/TagList.astro';

import type { BlogContentType } from '@/lib/queries/posts.ts';

const PLACEHOLDER_COVER = '/placeholder-cover.png';

interface Props {
    post: PostRow;
    tags: TagRow[];
    type: BlogContentType;
}

const { post, tags, type } = Astro.props;

function detailHref(contentType: BlogContentType, slug: string): string {
    if (contentType === 'book-note') {
        return `/booknote/${slug}/`;
    }
    return `/${contentType}/${slug}/`;
}

const typeLabel: Record<BlogContentType, string> = {
    post: 'Post',
    snippet: 'Snippet',
    'book-note': 'Book Note',
};

const href = detailHref(type, post.slug);
const meta = [typeLabel[type], post.date].filter(Boolean).join(' · ');
---

<article class="card-ruled border-b border-rule pb-4">
    <a href={href} class="mb-3 block overflow-hidden">
        <CoverImage
            cover={post.cover_image}
            placeholder={PLACEHOLDER_COVER}
            sizes="card"
            imgClassName="aspect-video w-full object-cover"
        />
    </a>
    <p class="kicker mb-1 text-[10px]">{meta}</p>
    <h2 class="font-display text-2xl font-bold leading-tight">
        <a href={href} class="text-ink no-underline hover:underline">{post.title}</a>
    </h2>
    {post.excerpt && <p class="mt-2 text-base text-charcoal line-clamp-2">{post.excerpt}</p>}
    <div class="rule-thin my-4"></div>
    <TagList tags={tags} />
    <a href={href} class="kicker mt-3 inline-block text-[10px] hover:underline">Read &rarr;</a>
</article>
