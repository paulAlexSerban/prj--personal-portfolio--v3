---
import type { TagRow } from '@prj--personal-portfolio--v3/shared--db-schema';

interface Props {
    tags: TagRow[];
}

const { tags } = Astro.props;
const slicedTags = tags.slice(0, 5);
---

{
    tags.length > 0 && (
        <ul class="m-0 flex list-none flex-wrap gap-[0.4rem] p-0">
            {slicedTags.map((tag) => (
                <li>
                    <a
                        href={`/tags/${tag.slug}/`}
                        class="inline-block border border-rule bg-highlight px-2 py-[0.15rem] text-xs text-ink no-underline hover:border-ink"
                    >
                        #{tag.name.toLowerCase()}
                    </a>
                </li>
            ))}
        </ul>
    )
}
