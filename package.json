{
    "name": "@prj--personal-portfolio--v3/core",
    "version": "0.0.1",
    "type": "module",
    "keywords": [],
    "repository": "https://github.com/paulAlexSerban/prj--personal-portfolio--v3.git",
    "author": "Paul Serban <paul.alex.serban@gmail.com>",
    "license": "MIT",
    "packageManager": "pnpm@11.5.0",
    "scripts": {
        "build": "pnpm -r build",
        "db:generate": "pnpm -r db:generate",
        "db:migrate": "pnpm -r db:migrate",
        "db:studio": "pnpm -r db:studio",
        "start:dry-run": "pnpm -r start:dry-run",
        "start": "pnpm -r start",
        "typecheck": "pnpm -r typecheck",
        "test": "pnpm -r test",
        "//": "FORMATS",
        "formats:check": "pnpm prettier --check .",
        "formats:write": "pnpm prettier --write .",
        "/": "GIT",
        "commit": "pnpm git-cz",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "commitizen": "^4.3.1",
        "git-cz": "^4.9.0",
        "prettier": "^3.8.3"
    },
    "private": true,
    "husky": {
        "hooks": {
            "prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true",
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
        }
    },
    "dependencies": {
        "husky": "^9.1.7"
    }
}
